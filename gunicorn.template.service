[Unit]
Description=gunicorn daemon
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/SITE_NAME
ExecStart=/home/ubuntu/SITE_NAME/venv/bin/gunicorn \
        --workers 3 \
        --bind unix:/home/ubuntu/SITE_NAME/gunicorn.sock \
        config.wsgi:application

[Install]
WantedBy=multi-user.target
